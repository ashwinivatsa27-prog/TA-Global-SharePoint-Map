<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Global Representation Map</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #ffffff;
    }

    svg {
      width: 100%;
      height: auto;
    }

    .country {
      fill: #e6e6e6;
      stroke: #ffffff;
      stroke-width: 0.5;
      cursor: pointer;
    }

    .country.active {
      fill: #2bb673; /* emerald-style highlight */
    }

    .country:hover {
      fill: #ffcc00;
    }

    #label {
      position: absolute;
      background: white;
      padding: 6px 10px;
      border: 1px solid #ccc;
      font-size: 12px;
      display: none;
      pointer-events: none;
    }
  </style>
</head>
<body>

<div id="label"></div>

<svg viewBox="0 0 1000 500"></svg>

<script src="https://d3js.org/d3.v7.min.js"></script>

<script>
  const svg = d3.select("svg");
  const label = document.getElementById("label");

  const projection = d3.geoNaturalEarth1()
    .scale(160)
    .translate([500, 260]);

  const path = d3.geoPath().projection(projection);

  // Example list of "represented" countries
  const activeCountries = [
    "United Kingdom",
    "France",
    "Germany",
    "India",
    "Brazil",
    "Canada"
  ];

  d3.json("world.geo.json").then(data => {
    svg.selectAll("path")
      .data(data.features)
      .enter()
      .append("path")
      .attr("d", path)
      .attr("class", d =>
        activeCountries.includes(d.properties.name)
          ? "country active"
          : "country"
      )
      .on("mousemove", (event, d) => {
        label.style.display = "block";
        label.style.left = event.pageX + 10 + "px";
        label.style.top = event.pageY + 10 + "px";
        label.innerText = d.properties.name;
      })
      .on("mouseout", () => {
        label.style.display = "none";
      });
  });
</script>

</body>
</html>
