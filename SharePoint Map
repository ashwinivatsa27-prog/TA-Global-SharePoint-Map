
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>TA Global SharePoint Map</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
    }

    svg {
      width: 100%;
      height: auto;
    }

    .country {
      fill: #e6e6e6;
      stroke: #ffffff;
      stroke-width: 0.5;
    }

    .country.active {
      fill: #2bb673;
    }

    .country:hover {
      fill: #ffcc00;
    }
  </style>
</head>
<body>

<svg viewBox="0 0 1000 500"></svg>

<script src="https://d3js.org/d3.v7.min.js"></script>

<script>
  const svg = d3.select("svg");

  const projection = d3.geoNaturalEarth1()
    .scale(160)
    .translate([500, 260]);

  const path = d3.geoPath().projection(projection);

  const activeCountries = [
    "United Kingdom",
    "France",
    "Germany",
    "India",
    "Brazil",
    "Canada"
  ];

  d3.json("world.geo.json").then(data => {
    svg.selectAll("path")
      .data(data.features)
      .enter()
      .append("path")
      .attr("d", path)
      .attr("class", d =>
        activeCountries.includes(d.properties.name)
          ? "country active"
          : "country"
      );
  });
</script>

</body>
</html>

